# backend/.env.example
# Copy this to .env.local and fill in your values.
# NEVER commit .env.local — it contains secrets.

# ── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1

# If running locally without an IAM role, set these.
# On ECS Fargate, leave them blank — the task role provides credentials.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Database (RDS PostgreSQL) ─────────────────────────────────────────────────
# docker-compose overrides DB_HOST/PORT/NAME/USER/PASSWORD with local values.
# Set these when deploying to AWS.
DB_HOST=
DB_PORT=5432
DB_NAME=jobsathi
DB_USER=jobsathi_admin
DB_PASSWORD=

# ── Redis (ElastiCache) ───────────────────────────────────────────────────────
REDIS_HOST=
REDIS_PORT=6379

# ── S3 ────────────────────────────────────────────────────────────────────────
S3_AUDIO_BUCKET=jobsathi-audio

# ── Job APIs ──────────────────────────────────────────────────────────────────
ADZUNA_APP_ID=
ADZUNA_API_KEY=
JOOBLE_API_KEY=

# ── SNS (Application Agent notifications) ────────────────────────────────────
# Create an SNS topic "JobSathi-EmployerNotifications" in the AWS console
# and paste its ARN here.
EMPLOYER_NOTIFICATIONS_SNS_ARN=

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=change-this-to-a-random-32-char-string
